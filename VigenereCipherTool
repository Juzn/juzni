import tkinter as tk
from tkinter import messagebox

class VigenereApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Шифр Віженера (Російська мова)")

        # Алфавіт: 32 літери (без 'ё')
        self.alphabet = "абвгдежзийклмнопрстуфхцчшщъыьэюя"
        self.m = len(self.alphabet)

        # Інтерфейс
        tk.Label(root, text="Введіть текст:").pack(pady=5)
        self.text_input = tk.Text(root, height=5, width=50)
        self.text_input.pack(pady=5)
        self.add_standard_bindings(self.text_input)

        tk.Label(root, text="Введіть ключ (слово):").pack(pady=5)
        self.key_input = tk.Entry(root, width=50)
        self.key_input.pack(pady=5)
        self.add_context_menu(self.key_input)

        btn_frame = tk.Frame(root)
        btn_frame.pack(pady=10)

        tk.Button(btn_frame, text="Зашифрувати", command=self.encrypt_action).grid(row=0, column=0, padx=10)
        tk.Button(btn_frame, text="Розшифрувати", command=self.decrypt_action).grid(row=0, column=1, padx=10)

        tk.Label(root, text="Результат:").pack(pady=5)
        self.result_output = tk.Text(root, height=5, width=50)
        self.result_output.pack(pady=5)
        self.add_standard_bindings(self.result_output)

    def add_standard_bindings(self, widget):
        widget.bind("<Control-a>", lambda e: self.select_all(widget))
        widget.bind("<Control-A>", lambda e: self.select_all(widget))
        self.add_context_menu(widget)

    def select_all(self, widget):
        widget.tag_add("sel", "1.0", "end")
        return "break"

    def add_context_menu(self, widget):
        menu = tk.Menu(self.root, tearoff=0)
        menu.add_command(label="Копіювати", command=lambda: widget.event_generate("<<Copy>>"))
        menu.add_command(label="Вставити", command=lambda: widget.event_generate("<<Paste>>"))
        menu.add_command(label="Вирізати", command=lambda: widget.event_generate("<<Cut>>"))
        menu.add_command(label="Виділити все", command=lambda: self.select_all(widget))

        def show_menu(event):
            menu.tk_popup(event.x_root, event.y_root)

        widget.bind("<Button-3>", show_menu)
        widget.bind("<Button-2>", show_menu)

    def filter_text(self, text):
        text = text.lower().replace("ё", "е")
        return "".join([c for c in text if c in self.alphabet])

    def vigenere_process(self, text, key, mode="encrypt"):
        text = self.filter_text(text)
        key = self.filter_text(key)
        if not key:
            return "Помилка: Ключ порожній!"
        result = []
        key_indices = [self.alphabet.index(k) for k in key]
        r = len(key_indices)
        for i in range(len(text)):
            x_i = self.alphabet.index(text[i])
            k_i = key_indices[i % r]
            y_i = (x_i + k_i) % self.m if mode == "encrypt" else (x_i - k_i) % self.m
            result.append(self.alphabet[y_i])
        return "".join(result)

    def encrypt_action(self):
        txt = self.text_input.get("1.0", "end-1c")
        key = self.key_input.get()
        res = self.vigenere_process(txt, key, "encrypt")
        self.result_output.delete("1.0", tk.END)
        self.result_output.insert(tk.END, res)

    def decrypt_action(self):
        txt = self.text_input.get("1.0", "end-1c")
        key = self.key_input.get()
        res = self.vigenere_process(txt, key, "decrypt")
        self.result_output.delete("1.0", tk.END)
        self.result_output.insert(tk.END, res)

if __name__ == "__main__":
    root = tk.Tk()
    app = VigenereApp(root)
    root.mainloop()
